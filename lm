def run_swarm_mode(parsed_args, prompt_text):
    task_queue = mp.Queue()
    result_queue = mp.Queue()
    plan_queue = mp.Queue()
    critique_request_queue = mp.Queue()
    critique_result_queue = mp.Queue()
    synth_request_queue = mp.Queue()
    synth_result_queue = mp.Queue()
    supervisor = ProcessSupervisor(
        heartbeat_timeout_sec=max(parsed_args.tool_timeout, 5),
        shutdown_timeout_sec=5,
        event_log_path=os.path.join(BASE_DIR, "docs", "process-events.jsonl"),
    )
    supervisor.register(
        WorkerSpec(
            agent_id="planner-1",
            role="planner",
            target=swarm_planner_worker,
            args=(task_queue, plan_queue, prompt_text, parsed_args.model, parsed_args.tool_timeout),
            max_restarts=1,
            heartbeat_sec=2,
        )
    )
    for i in range(parsed_args.swarm_workers):
        worker_id = f"worker-{i + 1}"
        supervisor.register(
            WorkerSpec(
                agent_id=worker_id,
                role="worker",
                target=swarm_worker_worker,
                args=(task_queue, result_queue, parsed_args.model, worker_id, parsed_args.tool_timeout),
                max_restarts=1,
                heartbeat_sec=2,
            )
        )
    supervisor.register(
        WorkerSpec(
            agent_id="critic-1",
            role="critic",
            target=swarm_critic_worker,
            args=(critique_request_queue, critique_result_queue, parsed_args.model, parsed_args.tool_timeout),
            max_restarts=1,
            heartbeat_sec=2,
        )
    )
    supervisor.register(
        WorkerSpec(
            agent_id="synthesizer-1",
            role="synthesizer",
            target=swarm_synthesizer_worker,
            args=(synth_request_queue, synth_result_queue, parsed_args.model, parsed_args.tool_timeout),
            max_restarts=1,
            heartbeat_sec=2,
        )
    )

    use_text_debug = parsed_args.debug and not parsed_args.tui
    use_tui = parsed_args.tui
    tui = SwarmTui(list(supervisor.workers.keys()), parsed_args.endpoint, parsed_args.model) if use_tui else None

    if use_text_debug:
        print("SWARM MODE")
        print(f"  endpoint: {parsed_args.endpoint}")
        print(f"  model: {parsed_args.model}")
        print(f"  agents: planner-1, workers={parsed_args.swarm_workers}, critic-1, synthesizer-1")
        print(f"  max_steps: {parsed_args.max_steps}")

    supervisor.start_all()
    live_context = Live(tui.render(), refresh_per_second=4, transient=False) if use_tui else nullcontext()
    final_results = []
    error_result = None
    critic_review = None
    synth_result = None
    ui_state = {"user_quit": False, "kb": None, "live": None}

    def drain_lifecycle():
        events = supervisor.drain_events()
        supervisor.check_workers()
        for event in events:
            if use_tui:
                tui.handle_event(event, supervisor)
        if use_tui:
            live.update(tui.render())
            if ui_state["kb"] is not None:
                key = ui_state["kb"].read_key()
                if key:
                    if key.lower() == "q":
                        ui_state["user_quit"] = True
                    else:
                        tui.handle_key(key)
                        live.update(tui.render())
        if use_text_debug:
            for event in events:
                event_name = event.get("event", "unknown")
                agent_id = event.get("agent_id", "n/a")
                suffix = ""
                if "task_id" in event:
                    suffix += f" task={event.get('task_id')}"
                if "request_id" in event:
                    suffix += f" request={event.get('request_id')}"
                if "msg" in event:
                    suffix += f" msg={event.get('msg')}"
                print(f"  lifecycle: {event_name} agent={agent_id}{suffix}")

    def wait_for_planner_count():
        deadline = time.time() + max(parsed_args.tool_timeout, 2)
        while time.time() < deadline:
            drain_lifecycle()
            try:
                plan_info = plan_queue.get(timeout=0.2)
            except queue.Empty:
                continue
            if plan_info.get("status") == "planned":
                count = int(plan_info.get("task_count", 0))
                if use_text_debug:
                    print(f"  planner: generated_tasks={count}")
                return count
        return None

    def collect_task_results(expected_count, label):
        if expected_count <= 0:
            return []
        batch_results = []
        seen_task_ids = set()
        deadline = time.time() + max(parsed_args.tool_timeout, 2) * max(expected_count, 1)
        while len(batch_results) < expected_count and time.time() < deadline:
            drain_lifecycle()
            try:
                result = result_queue.get(timeout=0.2)
            except queue.Empty:
                continue

            task_id = result.get("task_id")
            if task_id in seen_task_ids:
                continue
            seen_task_ids.add(task_id)
            if use_text_debug:
                print(
                    f"  result: batch={label} task={task_id} status={result.get('status')} "
                    f"agent={result.get('agent_id')}"
                )
            if result.get("status") != "done":
                return None, f"Worker error on {task_id}: {result.get('output', 'unknown error')}"
            batch_results.append(result)
            final_results.append(result)

        if len(batch_results) < expected_count:
            return None, f"Timed out waiting for task results in batch '{label}'."
        return batch_results, None

    def request_critic_review(review_id):
        critique_request_queue.put(
            {
                "request_id": review_id,
                "goal": prompt_text,
                "results": final_results,
            }
        )
        deadline = time.time() + max(parsed_args.tool_timeout, 2)
        while time.time() < deadline:
            drain_lifecycle()
            try:
                return critique_result_queue.get(timeout=0.2)
            except queue.Empty:
                continue
        return None

    def request_synthesis():
        synth_request_queue.put(
            {
                "request_id": "synth-1",
                "goal": prompt_text,
                "results": final_results,
                "critic_summary": critic_review.get("summary", "") if critic_review else "",
            }
        )
        deadline = time.time() + max(parsed_args.tool_timeout, 2)
        while time.time() < deadline:
            drain_lifecycle()
            try:
                return synth_result_queue.get(timeout=0.2)
            except queue.Empty:
                continue
        return None

    with live_context as live, KeyboardController(use_tui) as kb:
        try:
            ui_state["kb"] = kb
            ui_state["live"] = live

            planned_count = wait_for_planner_count()
            if ui_state["user_quit"]:
                error_result = "Swarm stopped by user (q)."
            if planned_count is None:
                error_result = "Planner did not return a task plan before timeout."
            else:
                _, batch_error = collect_task_results(planned_count, "initial")
                if batch_error:
                    error_result = batch_error

            review_round = 1
            task_seq = planned_count or 0
            while error_result is None and final_results and review_round <= parsed_args.swarm_max_reviews:
                if ui_state["user_quit"]:
                    error_result = "Swarm stopped by user (q)."
                    break
                critic_review = request_critic_review(f"review-{review_round}")
                if not critic_review:
                    error_result = "Critic did not return a review before timeout."
                    break

                if use_text_debug:
                    status = critic_review.get("status", "unknown")
                    print(f"  critic: round={review_round} status={status}")

                if critic_review.get("status") == "pass":
                    break

                follow_ups = critic_review.get("follow_up_tasks", [])
                if not isinstance(follow_ups, list):
                    follow_ups = []
                follow_ups = [task for task in follow_ups if isinstance(task, str) and task.strip()]

                if critic_review.get("schema_invalid"):
                    if use_text_debug:
                        print("  critic: schema invalid, continuing with synthesis fallback path")
                    break

                if not follow_ups:
                    break
                if review_round >= parsed_args.swarm_max_reviews:
                    break

                if use_text_debug:
                    print(f"  critic: enqueue_followups={len(follow_ups)}")
                for task_text in follow_ups:
                    if ui_state["user_quit"]:
                        error_result = "Swarm stopped by user (q)."
                        break
                    role_hint = derive_role_hint_from_text(task_text)
                    task_seq += 1
                    task_queue.put(
                        {
                            "task_id": f"task-{task_seq}",
                            "instruction": task_text.strip(),
                            "role_hint": role_hint,
                            "prompt_template_id": role_hint,
                            "created_by": "critic-1",
                        }
                    )
                if ui_state["user_quit"]:
                    break

                _, batch_error = collect_task_results(len(follow_ups), f"retry-{review_round}")
                if batch_error:
                    error_result = batch_error
                    break
                review_round += 1

            critic_ok = critic_review and (
                critic_review.get("status") == "pass" or critic_review.get("schema_invalid")
            )
            if error_result is None and critic_ok:
                if ui_state["user_quit"]:
                    error_result = "Swarm stopped by user (q)."
                else:
                    synth_result = request_synthesis()
                    if not synth_result:
                        synth_result = {
                            "status": "error",
                            "final_answer": "",
                            "details": "Synthesizer did not return a result before timeout.",
                        }
        finally:
            supervisor.shutdown()
            final_events = supervisor.drain_events()
            if use_tui:
                for event in final_events:
                    tui.handle_event(event, supervisor)
                live.update(tui.render())
            if use_text_debug:
                for event in final_events:
                    print(f"  lifecycle: {event.get('event', 'unknown')} agent={event.get('agent_id', 'n/a')}")

    output_payload = build_swarm_output_payload(
        parsed_args=parsed_args,
        prompt_text=prompt_text,
        critic_review=critic_review,
        synth_result=synth_result,
        final_results=final_results,
        error_result=error_result,
    )

    if parsed_args.output_format == "json":
        print(json.dumps(output_payload, ensure_ascii=True, indent=2))
        return

    if output_payload["status"] == "error":
        print(output_payload.get("error", "Unknown swarm error"))
    elif output_payload["status"] == "timeout":
        print(output_payload.get("error", "Swarm timeout"))
    elif output_payload["status"] == "rejected":
        print(output_payload.get("error", "Critic rejected output"))
    else:
        print(output_payload.get("final_answer", ""))
        if output_payload.get("fallback_used") and use_text_debug:
            print(f"\n[SYNTH FALLBACK] {output_payload.get('error', '')}")
        elif use_text_debug and critic_review and critic_review.get("status") == "pass":
            print(f"\n[CRITIC] pass: {critic_review.get('feedback', '')}")
            if critic_review.get("summary"):
                print(f"[CRITIC SUMMARY] {critic_review.get('summary')}")
            if synth_result and synth_result.get("details"):
                print(f"[SYNTH DETAILS] {synth_result.get('details')}")

def load_tools():
    """Loads schemas and functions from the tools/ directory."""
    tool_schemas = []
    tool_functions = {}
    if os.path.exists(TOOLS_DIR):
        for f in os.listdir(TOOLS_DIR):
            if f.endswith('.py') and f != '__init__.py':
                module_name = f[:-3]
                spec = importlib.util.spec_from_file_location(module_name, os.path.join(TOOLS_DIR, f))
                module = importlib.util.module_from_spec(spec)
                spec.loader.exec_module(module)
                
                if hasattr(module, 'SCHEMA'):
                    # Ensure the tool name in schema matches the filename for consistent lookup
                    module.SCHEMA['function']['name'] = module_name
                    tool_schemas.append(module.SCHEMA)
                
                if hasattr(module, 'execute'):
                    tool_functions[module_name] = module.execute
    return tool_schemas, tool_functions

