def short_text(value, max_len=240):
    text = str(value).strip()
    if len(text) <= max_len:
        return text
    return text[:max_len] + "..."


def extract_debug_lines(message):
    """Extract compact debug lines from model fields/content."""
    lines = []

    thinking = getattr(message, 'thinking', None) or getattr(message, 'reasoning', None)
    if thinking:
        lines.append(f"reasoning: {short_text(thinking)}")

    content = (getattr(message, 'content', None) or "").strip()
    if not content:
        return lines

    # If model follows optional bracketed debug sections, surface them first.
    for label in ("PLAN", "SELF_CHECK", "NEXT_ACTION", "VERIFY"):
        marker = f"[{label}]"
        for raw_line in content.splitlines():
            line = raw_line.strip()
            if line.startswith(marker):
                lines.append(f"{label.lower()}: {short_text(line[len(marker):].strip())}")

    if not lines:
        lines.append(f"content: {short_text(content)}")

    return lines


def call_ollama_with_timeout(model_name, messages, timeout_sec, tools=None):
    """Run an Ollama chat call with a hard timeout."""
    kwargs = {"model": model_name, "messages": messages}
    if tools is not None:
        kwargs["tools"] = tools
    with ThreadPoolExecutor(max_workers=1) as pool:
        future = pool.submit(ollama.chat, **kwargs)
        return future.result(timeout=timeout_sec)


def get_response_field(response, field_name, default=None):
    """Safely read fields from Ollama response objects or dict-like responses."""
    if response is None:
        return default
    value = getattr(response, field_name, None)
    if value is not None:
        return value
    if isinstance(response, dict):
        return response.get(field_name, default)
    return default


def extract_token_usage(response):
    """Extract token counters from Ollama response if available."""
    prompt_tokens = get_response_field(response, "prompt_eval_count", 0) or 0
    completion_tokens = get_response_field(response, "eval_count", 0) or 0
    total_tokens = int(prompt_tokens) + int(completion_tokens)
    return {
        "prompt_tokens": int(prompt_tokens),
        "completion_tokens": int(completion_tokens),
        "total_tokens": int(total_tokens),
    }


def emit_worker_error(event_queue, agent_id, role, error_type, details, **extra):
    """Emit a normalized error event for worker/coordinator observability."""
    payload = {
        "agent_id": agent_id,
        "role": role,
        "error_type": error_type,
        "details": short_text(details, max_len=240),
    }
    payload.update(extra)
    emit_event(event_queue, "worker_error", **payload)


def parse_json_payload(text):
    """Parse JSON even if the model adds wrappers, fences, or trailing text."""
    decoder = json.JSONDecoder()
    raw = (text or "").strip()
    if not raw:
        raise ValueError("empty response")

    candidates = [raw]
    if raw.startswith("```"):
        lines = raw.splitlines()
        if len(lines) >= 3 and lines[-1].strip() == "```":
            candidates.append("\n".join(lines[1:-1]).strip())
            if lines[0].strip().lower().startswith("```json"):
                candidates.append("\n".join(lines[1:-1]).strip())

    for candidate in candidates:
        if not candidate:
            continue
        try:
            return json.loads(candidate)
        except Exception:  # noqa: BLE001
            pass

        # Fallback: find first JSON object/array and decode only that.
        for idx, ch in enumerate(candidate):
            if ch not in "{[":
                continue
            try:
                parsed, _end = decoder.raw_decode(candidate[idx:])
                return parsed
            except Exception:  # noqa: BLE001
                continue

    raise ValueError("no valid JSON payload found")


def normalize_critic_review_payload(parsed):
    """Validate and normalize critic response schema."""
    if not isinstance(parsed, dict):
        return None
    status = parsed.get("status")
    if status not in {"pass", "fail"}:
        return None
    follow_up_tasks = parsed.get("follow_up_tasks", [])
    normalized_follow_ups = []
    if isinstance(follow_up_tasks, list):
        for item in follow_up_tasks:
            if isinstance(item, str) and item.strip():
                normalized_follow_ups.append(item.strip())
    return {
        "status": status,
        "feedback": str(parsed.get("feedback", "")),
        "summary": str(parsed.get("summary", "")),
        "follow_up_tasks": normalized_follow_ups[:5],
        "schema_invalid": False,
    }


def normalize_synth_payload(parsed):
    """Validate and normalize synthesizer response schema."""
    if not isinstance(parsed, dict):
        return None
    status = parsed.get("status")
    if status not in {"ok", "error"}:
        return None
    return {
        "status": status,
        "final_answer": str(parsed.get("final_answer", "")),
        "details": str(parsed.get("details", "")),
    }


def build_swarm_output_payload(parsed_args, prompt_text, critic_review, synth_result, final_results, error_result):
    """Build final structured output payload for swarm mode."""
    output_payload = {
        "mode": "swarm",
        "status": "error",
        "error_type": None,
        "goal": prompt_text,
        "critic_review": critic_review,
        "synth_result": synth_result,
        "results": final_results,
        "error": error_result,
        "fallback_used": False,
    }

    if error_result:
        output_payload["status"] = "error"
        if "timeout" in error_result.lower():
            output_payload["error_type"] = "timeout"
        elif "stopped by user" in error_result.lower():
            output_payload["error_type"] = "user_interrupt"
        elif "worker error" in error_result.lower():
            output_payload["error_type"] = "worker_error"
        else:
            output_payload["error_type"] = "runtime_error"
        return output_payload

    if final_results:
        critic_ok = critic_review and (
            critic_review.get("status") == "pass" or critic_review.get("schema_invalid")
        )
        if critic_ok and synth_result and synth_result.get("status") == "ok":
            output_payload["status"] = "ok"
            output_payload["final_answer"] = synth_result.get("final_answer", "")
        elif critic_ok:
            output_payload["status"] = "ok"
            output_payload["fallback_used"] = True
            output_payload["final_answer"] = "\n\n".join(
                f"[{item.get('task_id')}] {item.get('output', '').strip()}"
                for item in sorted(final_results, key=lambda r: r.get("task_id", ""))
            )
            output_payload["error"] = (
                synth_result.get("details", "unknown synthesizer issue") if synth_result else "unknown synthesizer issue"
            )
        else:
            output_payload["status"] = "rejected"
            feedback = critic_review.get("feedback", "") if critic_review else ""
            output_payload["error"] = f"Critic rejected final output. {feedback}".strip()
            output_payload["error_type"] = "critic_rejected"
        return output_payload

    output_payload["status"] = "timeout"
    output_payload["error"] = f"Swarm mode stopped after max steps ({parsed_args.max_steps}) without a final result."
    output_payload["error_type"] = "timeout"
    return output_payload


def extract_message_content(message):
    if message is None:
        return ""
    value = getattr(message, "content", None)
    if value is not None:
        return value or ""
    if isinstance(message, dict):
        return message.get("content", "") or ""
    return ""


def extract_message_tool_calls(message):
    if message is None:
        return []
    value = getattr(message, "tool_calls", None)
    if value is not None:
        return value or []
    if isinstance(message, dict):
        return message.get("tool_calls", []) or []
    return []


def extract_tool_call_name_and_args(tool_call):
    fn = getattr(tool_call, "function", None)
    if fn is not None:
        return getattr(fn, "name", None), getattr(fn, "arguments", {})
    if isinstance(tool_call, dict):
        fn = tool_call.get("function", {})
        return fn.get("name"), fn.get("arguments", {})
    return None, {}


def run_worker_task_with_tools(instruction, model_name, system_prompt, timeout_sec, max_steps=8):
    """Run a worker task with tool-calling loop and aggregate token usage."""
    tool_schemas, tool_functions = load_tools()
    messages = [
        {"role": "system", "content": system_prompt},
        {"role": "user", "content": instruction},
    ]
    usage_totals = {"prompt_tokens": 0, "completion_tokens": 0, "total_tokens": 0}
    tool_calls_executed = 0
    final_content = ""

    for _ in range(max_steps):
        response = call_ollama_with_timeout(model_name, messages, timeout_sec, tools=tool_schemas)
        usage = extract_token_usage(response)
        usage_totals["prompt_tokens"] += usage["prompt_tokens"]
        usage_totals["completion_tokens"] += usage["completion_tokens"]
        usage_totals["total_tokens"] += usage["total_tokens"]

        message = getattr(response, "message", None) if response is not None else None
        if message is None and isinstance(response, dict):
            message = response.get("message")

        messages.append(message)
        final_content = (extract_message_content(message) or "").strip()
        tool_calls = extract_message_tool_calls(message)
        if not tool_calls:
            break

        for tool_call in tool_calls:
            func_name, args = extract_tool_call_name_and_args(tool_call)
            if not func_name:
                continue
            if isinstance(args, str):
                try:
                    args = json.loads(args)
                except Exception:  # noqa: BLE001
                    args = {}
            if not isinstance(args, dict):
                args = {}

            if func_name not in tool_functions:
                tool_result = f"Tool '{func_name}' is not registered."
            else:
                try:
                    tool_result = tool_functions[func_name](**args)
                except Exception as err:  # noqa: BLE001
                    tool_result = f"Tool execution error for '{func_name}': {err}"

            tool_calls_executed += 1
            messages.append(
                {
                    "role": "tool",
                    "name": func_name,
                    "content": str(tool_result),
                }
            )
    else:
        final_content = (
            final_content
            or f"Stopped after max worker reasoning/tool steps ({max_steps}) for instruction: {instruction[:120]}"
        )

    return {
        "output": final_content,
        "tokens": usage_totals,
        "tool_calls_executed": tool_calls_executed,
    }


def normalize_planned_tasks(parsed, goal):
    """Normalize planner output into task objects with optional role/profile hints."""
    allowed_hints = set(WORKER_PROMPT_PROFILES.keys())
    tasks = []
    if isinstance(parsed, list):
        for item in parsed:
            if isinstance(item, str) and item.strip():
                tasks.append(
                    {
                        "instruction": item.strip(),
                        "role_hint": "general",
                        "prompt_template_id": "general",
                    }
                )
                continue
            if isinstance(item, dict):
                instruction = str(item.get("instruction", "")).strip()
                if not instruction:
                    continue
                role_hint = str(item.get("role_hint", "general")).strip().lower() or "general"
                prompt_template_id = str(item.get("prompt_template_id", role_hint)).strip().lower() or "general"
                if role_hint not in allowed_hints:
                    role_hint = "general"
                if prompt_template_id not in allowed_hints:
                    prompt_template_id = role_hint if role_hint in allowed_hints else "general"
                tasks.append(
                    {
                        "instruction": instruction,
                        "role_hint": role_hint,
                        "prompt_template_id": prompt_template_id,
                    }
                )
    if not tasks:
        tasks = [
            {
                "instruction": goal,
                "role_hint": "general",
                "prompt_template_id": "general",
            }
        ]
    return tasks[:5]


def derive_role_hint_from_text(text):
    """Simple heuristic for follow-up tasks that lack explicit role hint."""
    t = (text or "").lower()
    if any(k in t for k in ("test", "coverage", "integration", "unit", "assert")):
        return "testing"
    if any(k in t for k in ("security", "vuln", "threat", "auth", "secret")):
        return "security"
    if any(k in t for k in ("doc", "readme", "documentation", "guide")):
        return "docs"
    if any(k in t for k in ("reliability", "failure", "resilien", "timeout", "recovery")):
        return "reliability"
    return "general"


class SwarmTui:
    def __init__(self, agent_ids, endpoint_name, model_name):
        self.endpoint_name = endpoint_name
        self.model_name = model_name
        now = time.time()
        self.processes = {
            agent_id: {
                "role": "unknown",
                "pid": "-",
                "state": "registered",
                "restarts": 0,
                "last_heartbeat": None,
                "heartbeat_count": 0,
                "last_seen": now,
                "total_tokens": 0,
            }
            for agent_id in agent_ids
        }
        self.events = []
        self.reasoning = {agent_id: [] for agent_id in agent_ids}
        self.view_mode = "dashboard"
        self._view_order = ["dashboard", "reasoning", "events", "processes"]
        self.token_totals = {"prompt_tokens": 0, "completion_tokens": 0, "total_tokens": 0}
        self.request_count = 0
        self.error_count = 0

    def _event_line(self, event):
        event_name = event.get("event", "unknown")
        agent_id = event.get("agent_id", "n/a")
        msg = event.get("msg")
        task_id = event.get("task_id")
        request_id = event.get("request_id")
        parts = [event_name, f"agent={agent_id}"]
        if msg:
            parts.append(f"msg={msg}")
        if task_id:
            parts.append(f"task={task_id}")
        if request_id:
            parts.append(f"request={request_id}")
        return " ".join(parts)

    def _append_reasoning(self, agent_id, text):
        if not text:
            return
        bucket = self.reasoning.setdefault(agent_id, [])
        bucket.append(short_text(text, max_len=220))
        self.reasoning[agent_id] = bucket[-6:]

    def handle_key(self, ch):
        if not ch:
            return
        if ch == "\t":
            idx = self._view_order.index(self.view_mode)
            self.view_mode = self._view_order[(idx + 1) % len(self._view_order)]
            return
        key = ch.lower()
        if key == "r":
            self.view_mode = "reasoning"
        elif key == "e":
            self.view_mode = "events"
        elif key == "p":
            self.view_mode = "processes"
        elif key == "d":
            self.view_mode = "dashboard"

    def handle_event(self, event, supervisor):
        now = time.time()
        agent_id = event.get("agent_id")
        if agent_id and agent_id not in self.processes:
            self.processes[agent_id] = {
                "role": event.get("role", "unknown"),
                "pid": "-",
                "state": "registered",
                "restarts": 0,
                "last_heartbeat": None,
                "heartbeat_count": 0,
                "last_seen": now,
                "total_tokens": 0,
            }

        if agent_id:
            info = self.processes[agent_id]
            info["role"] = event.get("role", info["role"])
            info["last_seen"] = now

            if event.get("event") == "heartbeat":
                info["last_heartbeat"] = now
                info["heartbeat_count"] += 1
            elif event.get("event") == "process_started":
                info["pid"] = event.get("pid", info["pid"])
                info["state"] = "running"
            elif event.get("event") in {"process_exiting", "process_shutdown_complete"}:
                info["state"] = "stopped"
            elif event.get("event") in {"process_died", "process_killed"}:
                info["state"] = "failed"

            if event.get("msg") in {"planning_completed", "task_completed", "review_completed", "synthesis_completed"}:
                summary = event.get("summary") or event.get("details")
                if summary:
                    self._append_reasoning(agent_id, summary)

        # Pull restart/state info from supervisor truth.
        for worker in supervisor.workers.values():
            pid = worker.pid if worker.pid is not None else "-"
            proc = self.processes.setdefault(
                worker.spec.agent_id,
                {
                    "role": worker.spec.role,
                    "pid": "-",
                    "state": "registered",
                    "restarts": 0,
                    "last_heartbeat": None,
                    "heartbeat_count": 0,
                    "last_seen": now,
                    "total_tokens": 0,
                },
            )
            proc["role"] = worker.spec.role
            proc["pid"] = pid
            proc["state"] = worker.state
            proc["restarts"] = worker.restarts

        if agent_id:
            pt = int(event.get("prompt_tokens", 0) or 0)
            ct = int(event.get("completion_tokens", 0) or 0)
            tt = int(event.get("total_tokens", 0) or 0)
            if tt > 0:
                self.request_count += 1
                self.processes[agent_id]["total_tokens"] += tt
                self.token_totals["prompt_tokens"] += pt
                self.token_totals["completion_tokens"] += ct
                self.token_totals["total_tokens"] += tt
            if event.get("event") == "worker_error":
                self.error_count += 1

        if event.get("event") != "heartbeat":
            self.events.append(self._event_line(event))
            self.events = self.events[-80:]

    def render(self):
        now = time.time()
        header = Panel(
            (
                f"Endpoint: {self.endpoint_name}    Model: {self.model_name}    View: {self.view_mode}"
                f"    Tokens: {self.token_totals['total_tokens']} "
                f"(prompt {self.token_totals['prompt_tokens']}, completion {self.token_totals['completion_tokens']})"
                f"    Requests: {self.request_count}    Errors: {self.error_count}"
            ),
            title="Swarm Runtime",
            border_style="green",
        )

        proc_table = Table(title="Processes", expand=True)
        proc_table.add_column("Agent")
        proc_table.add_column("Role")
        proc_table.add_column("PID")
        proc_table.add_column("State")
        proc_table.add_column("Restarts")
        proc_table.add_column("Heartbeat Age")
        proc_table.add_column("Tokens")
        for agent_id in sorted(self.processes.keys()):
            info = self.processes[agent_id]
            hb = info.get("last_heartbeat")
            hb_age = "-" if hb is None else f"{now - hb:.1f}s"
            proc_table.add_row(
                agent_id,
                str(info.get("role", "unknown")),
                str(info.get("pid", "-")),
                str(info.get("state", "unknown")),
                str(info.get("restarts", 0)),
                hb_age,
                str(info.get("total_tokens", 0)),
            )

        hb_table = Table(title="Heartbeats", expand=True)
        hb_table.add_column("Agent")
        hb_table.add_column("Count")
        hb_table.add_column("Last Seen")
        for agent_id in sorted(self.processes.keys()):
            info = self.processes[agent_id]
            last_seen = info.get("last_seen", now)
            hb_table.add_row(
                agent_id,
                str(info.get("heartbeat_count", 0)),
                f"{now - last_seen:.1f}s ago",
            )

        reasoning_lines = []
        for agent_id in sorted(self.reasoning.keys()):
            notes = self.reasoning.get(agent_id, [])
            if notes:
                reasoning_lines.append(f"{agent_id}:")
                for note in notes[-3:]:
                    reasoning_lines.append(f"  - {note}")
        reasoning_text = "\n".join(reasoning_lines) if reasoning_lines else "No reasoning summaries yet."
        reasoning_panel = Panel(reasoning_text, title="Reasoning", border_style="magenta")

        events_text = "\n".join(self.events[-20:]) if self.events else "No events yet."
        events_panel = Panel(events_text, title="Recent Events", border_style="cyan")
        shortcuts = Panel(
            "[Tab] cycle view   [d] dashboard   [r] reasoning   [e] events   [p] processes   [q] quit",
            border_style="yellow",
            title="Shortcuts",
        )

        layout = Layout()
        layout.split_column(
            Layout(header, name="header", size=3),
            Layout(name="body"),
            Layout(shortcuts, name="shortcuts", size=3),
        )

        body = layout["body"]
        if self.view_mode == "reasoning":
            body.update(reasoning_panel)
        elif self.view_mode == "events":
            body.update(events_panel)
        elif self.view_mode == "processes":
            body.split_row(
                Layout(proc_table, name="proc", ratio=2),
                Layout(hb_table, name="hb", ratio=1),
            )
        else:
            body.split_row(
                Layout(name="left", ratio=1),
                Layout(name="right", ratio=1),
            )
            body["left"].split_column(
                Layout(proc_table, name="proc"),
                Layout(hb_table, name="hb"),
            )
            body["right"].split_column(
                Layout(reasoning_panel, name="reason"),
                Layout(events_panel, name="events"),
            )
        return layout


class KeyboardController:
    def __init__(self, enabled):
        self.enabled = enabled and sys.stdin.isatty()
        self.fd = None
        self.old_settings = None

    def __enter__(self):
        if not self.enabled:
            return self
        self.fd = sys.stdin.fileno()
        self.old_settings = termios.tcgetattr(self.fd)
        tty.setcbreak(self.fd)
        return self

    def __exit__(self, exc_type, exc, tb):
        if self.enabled and self.fd is not None and self.old_settings is not None:
            termios.tcsetattr(self.fd, termios.TCSADRAIN, self.old_settings)

    def read_key(self):
        if not self.enabled or self.fd is None:
            return None
        rlist, _, _ = select.select([sys.stdin], [], [], 0)
        if not rlist:
            return None
        try:
            return os.read(self.fd, 1).decode("utf-8", errors="ignore")
        except Exception:
            return None


def swarm_planner_worker(
    stop_event,
    event_queue,
    task_queue,
    plan_queue,
    goal,
    model_name,
    model_timeout_sec,
):
    emit_event(event_queue, "worker_progress", agent_id="planner-1", role="planner", msg="planning_started")
    tasks = []
    planner_tokens = {"prompt_tokens": 0, "completion_tokens": 0, "total_tokens": 0}
    try:
        response = call_ollama_with_timeout(
            model_name,
            [
                {
                    "role": "system",
                    "content": (
                        "You are a planning agent. Break the user goal into 1-5 concrete tasks. "
                        "Return only valid JSON array. Preferred item schema: "
                        "{\"instruction\": string, \"role_hint\": one of [general,reliability,testing,security,docs], "
                        "\"prompt_template_id\": one of [general,reliability,testing,security,docs]}. "
                        "String items are also accepted as fallback."
                    ),
                },
                {"role": "user", "content": goal},
            ],
            model_timeout_sec,
        )
        planner_tokens = extract_token_usage(response)
        content = (response.message.content or "").strip()
        parsed = parse_json_payload(content)
        normalized_tasks = normalize_planned_tasks(parsed, goal)
        tasks = normalized_tasks
    except TimeoutError:
        emit_worker_error(
            event_queue,
            agent_id="planner-1",
            role="planner",
            error_type="model_timeout",
            details=f"planner model call exceeded {model_timeout_sec}s",
            msg="planning_timeout",
        )
    except Exception as err:  # noqa: BLE001
        emit_worker_error(
            event_queue,
            agent_id="planner-1",
            role="planner",
            error_type="planner_error",
            details=str(err),
            msg="planning_fallback",
        )

    if not tasks:
        tasks = normalize_planned_tasks([], goal)

    task_count = min(len(tasks), 5)
    for i in range(task_count):
        task = {
            "task_id": f"task-{i + 1}",
            "instruction": tasks[i]["instruction"],
            "role_hint": tasks[i].get("role_hint", "general"),
            "prompt_template_id": tasks[i].get("prompt_template_id", "general"),
            "created_by": "planner-1",
        }
        task_queue.put(task)

    plan_queue.put({"status": "planned", "task_count": task_count})
    emit_event(
        event_queue,
        "worker_progress",
        agent_id="planner-1",
        role="planner",
        msg="planning_completed",
        task_count=task_count,
        summary=(
            "Planned "
            f"{task_count} task(s): "
            + ", ".join(
                f"{task['instruction'][:40]} ({task.get('role_hint', 'general')})"
                for task in tasks[:3]
            )
        ),
        prompt_tokens=planner_tokens["prompt_tokens"],
        completion_tokens=planner_tokens["completion_tokens"],
        total_tokens=planner_tokens["total_tokens"],
    )

    # Keep process alive so heartbeat tracking remains visible until shutdown.
    while not stop_event.is_set():
        time.sleep(0.2)


def swarm_worker_worker(
    stop_event,
    event_queue,
    task_queue,
    result_queue,
    model_name,
    agent_id,
    model_timeout_sec,
):
    while not stop_event.is_set():
        try:
            task = task_queue.get(timeout=0.3)
        except queue.Empty:
            continue

        task_id = task.get("task_id", "task-unknown")
        instruction = task.get("instruction", "")
        prompt_template_id = str(task.get("prompt_template_id", task.get("role_hint", "general"))).strip().lower()
        if prompt_template_id not in WORKER_PROMPT_PROFILES:
            prompt_template_id = "general"
        emit_event(
            event_queue,
            "worker_progress",
            agent_id=agent_id,
            role="worker",
            task_id=task_id,
            msg="task_started",
            prompt_template_id=prompt_template_id,
        )
        try:
            worker_result = run_worker_task_with_tools(
                instruction=instruction,
                model_name=model_name,
                system_prompt=(
                    WORKER_PROMPT_PROFILES[prompt_template_id]
                    + " Use available tools when needed. "
                    "If the task asks for creating/updating files, perform the writes via tools instead of only describing a plan."
                ),
                timeout_sec=model_timeout_sec,
                max_steps=8,
            )
            worker_tokens = worker_result["tokens"]
            output = (worker_result.get("output") or "").strip()
            result_queue.put(
                {
                    "task_id": task_id,
                    "status": "done",
                    "output": output,
                    "agent_id": agent_id,
                    "prompt_template_id": prompt_template_id,
                    "tool_calls_executed": worker_result.get("tool_calls_executed", 0),
                }
            )
            emit_event(
                event_queue,
                "worker_progress",
                agent_id=agent_id,
                role="worker",
                task_id=task_id,
                msg="task_completed",
                summary=short_text(output, max_len=180),
                prompt_template_id=prompt_template_id,
                tool_calls_executed=worker_result.get("tool_calls_executed", 0),
                prompt_tokens=worker_tokens["prompt_tokens"],
                completion_tokens=worker_tokens["completion_tokens"],
                total_tokens=worker_tokens["total_tokens"],
            )
        except TimeoutError:
            error_payload = {
                "task_id": task_id,
                "status": "error",
                "output": f"worker model call exceeded {model_timeout_sec}s",
                "agent_id": agent_id,
                "prompt_template_id": prompt_template_id,
            }
            result_queue.put(error_payload)
            emit_worker_error(
                event_queue,
                agent_id=agent_id,
                role="worker",
                error_type="model_timeout",
                details=f"worker model call exceeded {model_timeout_sec}s",
                task_id=task_id,
                msg="task_timeout",
            )
        except Exception as err:  # noqa: BLE001
            error_payload = {
                "task_id": task_id,
                "status": "error",
                "output": str(err),
                "agent_id": agent_id,
                "prompt_template_id": prompt_template_id,
            }
            result_queue.put(error_payload)
            emit_worker_error(
                event_queue,
                agent_id=agent_id,
                role="worker",
                error_type="worker_error",
                details=str(err),
                task_id=task_id,
                msg="task_failed",
            )


def swarm_critic_worker(
    stop_event,
    event_queue,
    critique_request_queue,
    critique_result_queue,
    model_name,
    model_timeout_sec,
):
    while not stop_event.is_set():
        try:
            request = critique_request_queue.get(timeout=0.3)
        except queue.Empty:
            continue

        request_id = request.get("request_id", "review-unknown")
        goal = request.get("goal", "")
        results = request.get("results", [])

        emit_event(
            event_queue,
            "worker_progress",
            agent_id="critic-1",
            role="critic",
            request_id=request_id,
            msg="review_started",
        )

        review_payload = {
            "status": "fail",
            "feedback": "No review generated.",
            "summary": "",
            "follow_up_tasks": [],
            "schema_invalid": False,
        }
        critic_tokens = {"prompt_tokens": 0, "completion_tokens": 0, "total_tokens": 0}
        try:
            response = call_ollama_with_timeout(
                model_name,
                [
                    {
                        "role": "system",
                        "content": (
                            "You are a critic in an agent swarm. Evaluate if worker outputs satisfy the goal. "
                            "Return only JSON object with keys: status (pass|fail), feedback, summary, follow_up_tasks. "
                            "follow_up_tasks must be an array of concrete task strings when status=fail, otherwise []."
                        ),
                    },
                    {
                        "role": "user",
                        "content": (
                            f"Goal:\n{goal}\n\n"
                            f"Worker outputs:\n{json.dumps(results, ensure_ascii=True)}"
                        ),
                    },
                ],
                model_timeout_sec,
            )
            usage = extract_token_usage(response)
            critic_tokens["prompt_tokens"] += usage["prompt_tokens"]
            critic_tokens["completion_tokens"] += usage["completion_tokens"]
            critic_tokens["total_tokens"] += usage["total_tokens"]
            content = (response.message.content or "").strip()
            parsed = parse_json_payload(content)
            normalized = normalize_critic_review_payload(parsed)
            if normalized:
                review_payload = normalized
            else:
                retry_response = call_ollama_with_timeout(
                    model_name,
                    [
                        {
                            "role": "system",
                            "content": (
                                "Return only valid JSON object. No prose. "
                                "Schema: status(pass|fail), feedback(string), summary(string), follow_up_tasks(array of strings)."
                            ),
                        },
                        {
                            "role": "user",
                            "content": (
                                f"Goal:\n{goal}\n\n"
                                f"Worker outputs:\n{json.dumps(results, ensure_ascii=True)}"
                            ),
                        },
                    ],
                    model_timeout_sec,
                )
                retry_usage = extract_token_usage(retry_response)
                critic_tokens["prompt_tokens"] += retry_usage["prompt_tokens"]
                critic_tokens["completion_tokens"] += retry_usage["completion_tokens"]
                critic_tokens["total_tokens"] += retry_usage["total_tokens"]
                retry_content = (retry_response.message.content or "").strip()
                retry_parsed = parse_json_payload(retry_content)
                normalized_retry = normalize_critic_review_payload(retry_parsed)
                if normalized_retry:
                    review_payload = normalized_retry
                else:
                    review_payload["feedback"] = "Critic returned invalid schema."
                    review_payload["schema_invalid"] = True
        except TimeoutError:
            review_payload["feedback"] = f"Critic timeout: model call exceeded {model_timeout_sec}s"
            emit_worker_error(
                event_queue,
                agent_id="critic-1",
                role="critic",
                error_type="model_timeout",
                details=review_payload["feedback"],
                request_id=request_id,
            )
        except Exception as err:  # noqa: BLE001
            review_payload["feedback"] = f"Critic error: {err}"
            emit_worker_error(
                event_queue,
                agent_id="critic-1",
                role="critic",
                error_type="critic_error",
                details=review_payload["feedback"],
                request_id=request_id,
            )

        review_payload["request_id"] = request_id
        critique_result_queue.put(review_payload)
        emit_event(
            event_queue,
            "worker_progress",
            agent_id="critic-1",
            role="critic",
            request_id=request_id,
            msg="review_completed",
            status=review_payload.get("status"),
            summary=short_text(
                f"status={review_payload.get('status')} feedback={review_payload.get('feedback', '')}",
                max_len=180,
            ),
            prompt_tokens=critic_tokens["prompt_tokens"],
            completion_tokens=critic_tokens["completion_tokens"],
            total_tokens=critic_tokens["total_tokens"],
        )


