import argparse
import sys
import os
import importlib.util
import ollama
import logging
import json
from concurrent.futures import ThreadPoolExecutor, TimeoutError

# Set logging levels to reduce noise
sys.stderr = open(os.devnull,"w")
os.environ["CURL_CFFI_LOG_LEVEL"] = "error"

MODEL_NAME = 'granite4:7b-a1b-h'
DEFAULT_MAX_STEPS = 12
DEFAULT_TOOL_TIMEOUT_SEC = 20

BASE_DIR = os.path.dirname(os.path.abspath(__file__))
SKILLS_DIR = os.path.join(BASE_DIR, "skills")
TOOLS_DIR = os.path.join(BASE_DIR, "tools")


def short_text(value, max_len=240):
    text = str(value).strip()
    if len(text) <= max_len:
        return text
    return text[:max_len] + "..."


def extract_debug_lines(message):
    """Extract compact debug lines from model fields/content."""
    lines = []

    thinking = getattr(message, 'thinking', None) or getattr(message, 'reasoning', None)
    if thinking:
        lines.append(f"reasoning: {short_text(thinking)}")

    content = (getattr(message, 'content', None) or "").strip()
    if not content:
        return lines

    # If model follows optional bracketed debug sections, surface them first.
    for label in ("PLAN", "SELF_CHECK", "NEXT_ACTION", "VERIFY"):
        marker = f"[{label}]"
        for raw_line in content.splitlines():
            line = raw_line.strip()
            if line.startswith(marker):
                lines.append(f"{label.lower()}: {short_text(line[len(marker):].strip())}")

    if not lines:
        lines.append(f"content: {short_text(content)}")

    return lines

def load_tools():
    """Loads schemas and functions from the tools/ directory."""
    tool_schemas = []
    tool_functions = {}
    if os.path.exists(TOOLS_DIR):
        for f in os.listdir(TOOLS_DIR):
            if f.endswith('.py') and f != '__init__.py':
                module_name = f[:-3]
                spec = importlib.util.spec_from_file_location(module_name, os.path.join(TOOLS_DIR, f))
                module = importlib.util.module_from_spec(spec)
                spec.loader.exec_module(module)
                
                if hasattr(module, 'SCHEMA'):
                    # Ensure the tool name in schema matches the filename for consistent lookup
                    module.SCHEMA['function']['name'] = module_name
                    tool_schemas.append(module.SCHEMA)
                
                if hasattr(module, 'execute'):
                    tool_functions[module_name] = module.execute
    return tool_schemas, tool_functions

def main():
    parser = argparse.ArgumentParser(
        description='A local AI agent powered by Ollama with web search & file tools.',
        epilog='''
Usage examples:
  lm "list files in current dir"
  git diff | lm "write a commit message"
  cat file.py | lm "explain this code"
''',
        formatter_class=argparse.RawDescriptionHelpFormatter)
    parser.add_argument('--debug', '-d', action='store_true', help='Show debug output (reasoning and tool calls)')
    parser.add_argument('--max-steps', type=int, default=DEFAULT_MAX_STEPS, help='Maximum agent loop iterations')
    parser.add_argument('--tool-timeout', type=int, default=DEFAULT_TOOL_TIMEOUT_SEC, help='Per-tool timeout in seconds')
    parser.add_argument('prompt', nargs='*', help='Prompt to send to the model')
    parsed_args = parser.parse_args()

    if not parsed_args.prompt:
        parser.print_help()
        return

    piped_content = sys.stdin.read() if not sys.stdin.isatty() else ""
    manual_args = " ".join(parsed_args.prompt)
    
    # Load available tools
    tool_schemas, tool_functions = load_tools()

    system_prompt = (
        "You are a local development assistant. "
        "IMPORTANT: You have tools to see the real filesystem and fetch external data like YouTube transcripts. "
        "Do not guess filenames or content. Use your tools to verify facts. "
        "If you use a tool, wait for the tool output before giving a final answer."
    )
    if parsed_args.debug:
        system_prompt += (
            " In debug mode, include compact trace lines in your responses when relevant: "
            "[PLAN], [SELF_CHECK], [NEXT_ACTION], and [VERIFY]."
        )

    # Initial user message construction
    user_input = manual_args + (f"\n\nCONTEXT:\n{piped_content}" if piped_content else "")
    
    if not user_input.strip():
        print("Error: No input provided. Please provide a prompt or pipe content to the script.")
        return

    messages = [
        {'role': 'system', 'content': system_prompt},
        {'role': 'user', 'content': user_input}
    ]

    try:
        # THE AGENT LOOP
        step = 0
        while step < parsed_args.max_steps:
            step += 1
            # Call Ollama with the current message history and tool definitions
            response = ollama.chat(
                model=MODEL_NAME, 
                messages=messages, 
                tools=tool_schemas
            )

            # Add the model's response (which may be a tool call or a final answer)
            messages.append(response.message)

            if parsed_args.debug:
                print(f"STEP {step}")
                for line in extract_debug_lines(response.message):
                    print(f"  {line}")

            # If the model didn't call any tools, it's done—print result and exit
            if not response.message.tool_calls:
                if response.message.content:
                    print(response.message.content)
                else:
                    print("Model returned an empty response.")
                break

            # Process tool calls if present
            for tool in response.message.tool_calls:
                func_name = tool.function.name
                args = tool.function.arguments

                # Ensure arguments are a dictionary (Ollama sometimes returns JSON strings)
                if isinstance(args, str):
                    try:
                        args = json.loads(args)
                    except json.JSONDecodeError:
                        error_msg = f"Invalid JSON arguments for tool '{func_name}'."
                        messages.append({'role': 'tool', 'content': error_msg, 'name': func_name})
                        if parsed_args.debug:
                            print(f"  tool_call: {func_name}({short_text(tool.function.arguments)})")
                            print(f"  tool_error: {short_text(error_msg)}")
                        continue

                if not isinstance(args, dict):
                    error_msg = f"Invalid argument payload for tool '{func_name}': expected object/dict."
                    messages.append({'role': 'tool', 'content': error_msg, 'name': func_name})
                    if parsed_args.debug:
                        print(f"  tool_call: {func_name}({short_text(args)})")
                        print(f"  tool_error: {short_text(error_msg)}")
                    continue

                if parsed_args.debug:
                    print(f"  tool_call: {func_name}({short_text(args)})")

                if func_name in tool_functions:
                    try:
                        with ThreadPoolExecutor(max_workers=1) as pool:
                            future = pool.submit(tool_functions[func_name], **args)
                            result = future.result(timeout=parsed_args.tool_timeout)

                        # Append the tool result to the conversation.
                        messages.append({
                            'role': 'tool',
                            'content': str(result),
                            'name': func_name
                        })
                        if parsed_args.debug:
                            print(f"  tool_result: {short_text(result)}")
                    except TimeoutError:
                        error_msg = json.dumps({
                            "error": "tool_timeout",
                            "tool": func_name,
                            "details": f"Tool timed out after {parsed_args.tool_timeout}s"
                        })
                        messages.append({'role': 'tool', 'content': error_msg, 'name': func_name})
                        if parsed_args.debug:
                            print(f"  tool_error: {short_text(error_msg)}")
                    except Exception as tool_err:
                        error_msg = json.dumps({
                            "error": "tool_execution_error",
                            "tool": func_name,
                            "details": str(tool_err)
                        })
                        messages.append({'role': 'tool', 'content': error_msg, 'name': func_name})
                        if parsed_args.debug:
                            print(f"  tool_error: {short_text(error_msg)}")
                else:
                    error_msg = json.dumps({
                        "error": "tool_not_registered",
                        "tool": func_name,
                        "details": "Tool is not registered in tool_functions."
                    })
                    messages.append({'role': 'tool', 'content': error_msg, 'name': func_name})
                    if parsed_args.debug:
                        print(f"  tool_error: {short_text(error_msg)}")

            # The loop repeats, sending the tool outputs back to the model for final synthesis
            if parsed_args.debug:
                messages.append({
                    'role': 'user',
                    'content': (
                        "DEBUG CHECK: Evaluate the latest tool outputs before your next action. "
                        "State [VERIFY] sufficient/insufficient with one reason. "
                        "If insufficient, continue with the next best tool call. "
                        "If sufficient, provide the final answer."
                    )
                })
        else:
            print(f"Stopped after reaching max steps ({parsed_args.max_steps}).", file=sys.stderr)

    except Exception as e:
        print(f"CRITICAL ERROR: {e}", file=sys.stderr)

if __name__ == "__main__":
    main()
